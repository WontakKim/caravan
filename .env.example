# Copy to .env and fill in real values. .env is gitignored.
#
# With no variables set, Caravan runs the built-in mock provider (no network).
# The settings below configure the OpenAI-compatible provider.

# Provider: "mock" (default) or "openai". Note: "openai" selects the
# OpenAI-compatible adapter; values other than these two are rejected at startup.
CARAVAN_MODEL_PROVIDER=openai

# Model name. Defaults: "mock-model" (mock) / "openai-model" (openai).
CARAVAN_MODEL=claude-sonnet-4-6

# OpenAI-compatible base URL. Default: https://api.openai.com/v1
CARAVAN_OPENAI_BASE_URL=https://model.wrtn.club/api/v1

# Name of the env var that holds the API key. Default: OPENAI_API_KEY
CARAVAN_OPENAI_API_KEY_ENV=OPENAI_API_KEY

# The API key itself (the variable named by CARAVAN_OPENAI_API_KEY_ENV).
OPENAI_API_KEY=sk-arena-REPLACE_ME

# HTTP client: "stub" (default, performs no real requests) or "blocking" (real HTTP).
CARAVAN_OPENAI_HTTP_CLIENT=blocking

# Request timeout in seconds (positive integer). Default: 30
CARAVAN_OPENAI_TIMEOUT_SECS=60
